{
  "profiles": [
    {
      "id": "A",
      "requiresFixtures": false,
      "description": "In-process serialization benchmark; no database fixtures required."
    },
    {
      "id": "B",
      "requiresFixtures": true,
      "description": "Mixed planning workload baseline using tenant-aware control-plane, workflow governance, and synthetic compat metadata.",
      "steps": [
        {
          "name": "migrate-only",
          "executable": "go",
          "arguments": [
            "-C",
            "services/grid-service",
            "run",
            "./src",
            "-migrate-only"
          ],
          "environment": {
            "DATABASE_URL": "postgres://{{DatabaseUser}}:{{DatabasePassword}}@{{DatabaseHost}}:55432/{{DatabaseName}}?sslmode=disable"
          }
        },
        {
          "name": "seed-tenant-governance",
          "executable": "psql",
          "arguments": [
            "-h",
            "{{DatabaseHost}}",
            "-U",
            "{{DatabaseUser}}",
            "-d",
            "{{DatabaseName}}",
            "-f",
            "services/grid-service/sql/seed/phase4_tenant_governance_seed.sql"
          ],
          "environment": {
            "PGPASSWORD": "{{DatabasePassword}}",
            "PGOPTIONS": "-c phase4.seed_prefix=phase4"
          }
        },
        {
          "name": "seed-compat-mixed-load",
          "executable": "psql",
          "arguments": [
            "-h",
            "{{DatabaseHost}}",
            "-U",
            "{{DatabaseUser}}",
            "-d",
            "{{DatabaseName}}",
            "-f",
            "services/grid-service/sql/seed/seed_compat.sql"
          ],
          "environment": {
            "PGPASSWORD": "{{DatabasePassword}}",
            "PGOPTIONS": "-c gridseed.model_id=phase4_profile_b"
          }
        },
        {
          "name": "seed-close-cycle-and-ai-governance",
